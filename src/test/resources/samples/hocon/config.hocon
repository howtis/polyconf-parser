// Application configuration in HOCON format
server {
  host = "0.0.0.0"
  port = 8080
  debug = false
}

database {
  host = "localhost"
  host = ${?DB_HOST}
  port = 5432
  port = ${?DB_PORT}
  name = "myapp"
  pool-size = 10

  credentials {
    username = "admin"
    password = "secret"
  }
}

features {
  enabled = ["auth", "logging", "metrics"]
  timeout-ms = 30000
  pi = 3.14

  rate-limit {
    max-requests = 1000
    window-seconds = 60
  }
}

# Override with environment variables
server.port = ${?SERVER_PORT}
