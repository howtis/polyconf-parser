// Application configuration
app {
  name = "myapp"
  version = "1.0.0"
  description = "A polyglot configuration parser"

  server {
    host = "0.0.0.0"
    host = ${?HOST}
    port = 8080
    port = ${?PORT}
  }
}

database {
  host = "localhost"
  host = ${?DB_HOST}
  port = 5432
  port = ${?DB_PORT}
  name = "myapp"
  pool-size = 10
}
