# Test environment settings
NODE_ENV=test
APP_ENV=test
APP_DEBUG=true

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
SERVER_WORKERS=1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_test
DB_USER=test_user
DB_PASS=test_pass
DB_POOL_MIN=1
DB_POOL_MAX=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Security
JWT_SECRET=test-secret-key
JWT_EXPIRY=60
CORS_ORIGIN=*

# External Services
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test-key
AWS_SECRET_ACCESS_KEY=test-secret
S3_BUCKET=app-uploads-test
SENTRY_DSN=

# Test-specific
TEST_TIMEOUT=10000
MOCK_ENABLED=true
