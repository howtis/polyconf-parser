# Docker Compose environment variables - real-world deployment config
# Used alongside docker-compose for 12-factor app configuration

# Application
APP_NAME=orders-service
APP_ENV=production
APP_DEBUG=false
APP_PORT=8080
APP_HOST=0.0.0.0
APP_LOG_LEVEL=info

# Database
DB_HOST=postgres-primary.internal
DB_PORT=5432
DB_NAME=orders
DB_USER=order_service
DB_PASSWORD=s3cure_p4ssw0rd!
DB_POOL_MIN=5
DB_POOL_MAX=25
DB_SSL_MODE=require
DB_SSL_ROOT_CERT=/etc/ssl/certs/ca-bundle.crt

# Redis
REDIS_HOST=redis-cluster.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_TIMEOUT_SEC=5

# Authentication
AUTH_ISSUER=https://auth.example.com/realms/orders
AUTH_CLIENT_ID=order-service
AUTH_CLIENT_SECRET=6Dg9kL2mN8pR4vW1xY3zB7cF0hJ5tQ
AUTH_TOKEN_EXPIRY=3600

# AWS / S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_DOCUMENTS=orders-documents-prod
S3_BUCKET_BACKUPS=orders-backups-prod
S3_ENDPOINT=https://s3.ap-northeast-2.amazonaws.com

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger-agent.monitoring.svc.cluster.local
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# Feature Flags
FEATURE_NEW_CHECKOUT=false
FEATURE_BATCH_PROCESSING=true
FEATURE_DARK_MODE=beta
